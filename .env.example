# ══════════════════════════════════════════════════════════════
#  ListMate — Environment Variables
#  Copy this file to .env and fill in your real values.
#  The app runs in demo mode for any missing key.
# ══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
PORT=4000
# Change to your real domain in production:
FRONTEND_URL=http://localhost:5173

# ── Anthropic (AI listing generation) ──────────────────────────
# Get your key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Supabase (auth & database — single source of truth) ────────
# Create a project at: https://supabase.com → Settings → API
# Then run supabase-setup.sql in the SQL Editor to create the tables.
#
# Frontend keys (browser-safe, used for auth):
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
#
# Server keys (used to store listing history + subscriptions in Supabase).
# SUPABASE_URL can be the same as VITE_SUPABASE_URL.
# The SERVICE ROLE key is SECRET — server-only, never expose it in the browser.
# Find it at: Supabase → Settings → API → service_role key.
# If these two are left blank, the server falls back to local JSON files.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe (subscriptions & payments) ──────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Price IDs — create products in the Stripe Dashboard first:
#   Dashboard → Products → Add product
#   Create "ListMate Starter" recurring £5.99/mo → copy the price ID (price_xxx)
#   Create "ListMate Pro"     recurring £11.99/mo → copy the price ID (price_xxx)
# If left blank, checkout falls back to ad-hoc price_data (still works, but not recommended for production).
STRIPE_STARTER_PRICE_ID=price_starter_xxx
STRIPE_PRO_PRICE_ID=price_pro_xxx

# Stripe Webhook Secret — get from the Stripe Dashboard:
#   Developers → Webhooks → Add endpoint → https://yourdomain.com/api/stripe-webhook
#   Listen for: checkout.session.completed
#               customer.subscription.updated
#               customer.subscription.deleted
#   Copy the signing secret (whsec_...) here.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
